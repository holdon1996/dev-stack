{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevStack",
  "version": "1.0.0",
  "identifier": "com.devstack.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DevStack",
        "width": 1024,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {},
      "wix": {}
    }
  },
  "plugins": {
    "shell": {},
    "fs": {},
    "updater": {
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
